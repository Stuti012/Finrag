        "\n",
        "    if all_ctx:\n",
        "        full_ctx = \" \".join(all_ctx)\n",
        "        suff = evaluator.context_metrics.context_sufficiency(\n",
        "            full_ctx, r.get('question', ''), r.get('gold_answer', '')\n",
