        "print(f\"  Mean Sufficiency: {ctx_metrics['mean_sufficiency']:.4f}\")\n",
        "\n",
        "# Analyze retrieval quality vs answer accuracy\n",
        "high_suff = []\n",
        "low_suff = []\n",
        "for r in eval_results:\n",
        "    retrieval = r.get('retrieval', {})\n",
        "    all_ctx = []\n",
