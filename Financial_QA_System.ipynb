        "            )['exact_match']\n",
        "\n",
        "        if suff['sufficiency_score'] >= 0.5:\n",
        "            high_suff.append(float(is_correct))\n",
        "        else:\n",
        "            low_suff.append(float(is_correct))\n",
        "\n",
        "print(f\"\\nAnswer Accuracy by Retrieval Quality:\")\n",
