        "        type_counts[t] += 1\n",
        "\n",
        "print(\"Question Type Distribution:\")\n",
        "for t, c in sorted(type_counts.items(), key=lambda x: -x[1]):\n",
        "    print(f\"  {t}: {c} ({c/len(train_examples)*100:.1f}%)\")\n",
        "print(f\"  multi-type: {multi_type} ({multi_type/len(train_examples)*100:.1f}%)\")"
