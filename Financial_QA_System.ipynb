        "\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# Ensure src is importable\n",
        "sys.path.insert(0, os.path.dirname(os.path.abspath('.')))\n",
        "sys.path.insert(0, '.')\n",
        "\n",
        "# Check available hardware\n",
